{ pkgs, lib, config, inputs, ... }:

{
{% if use_terraform %}
  languages.terraform.enable = true;
{% endif %}

  # https://devenv.sh/packages/
  packages = [
    pkgs.git
{% if use_terraform %}
    pkgs.tflint
    pkgs.terraform-docs
{% endif %}
{% if ansible_enabled %}
    pkgs.ansible
    pkgs.ansible-lint
{% endif %}
  ];

  enterShell = ''
{% if use_terraform %}
    for env in staging production; do
      if [ ! -f "terraform/environments/$env/terraform.tfvars" ]; then
        cp "terraform/environments/$env/terraform.tfvars.example" "terraform/environments/$env/terraform.tfvars"
      fi
    done
{% endif %}
    lefthook install
  '';
}
