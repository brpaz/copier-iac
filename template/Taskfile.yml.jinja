# https://taskfile.dev

version: "3"

env:
  FORCE_COLOR: "true"
  SSH_KEY_NAME: "provision"

includes:
{% if use_terraform %}
  tf:
    dir: terraform
    taskfile: ./terraform/Taskfile.yml
{% endif %}
{% if ansible_enabled %}
  ansible:
    dir: ansible
    taskfile: ./ansible/Taskfile.yml
{% endif %}

tasks:
  default:
    desc: "Shows list of available tasks"
    cmds:
      - task -l
    silent: true

  gen-ssh-key:
    desc: "Generate SSH key"
    interactive: true
    env:
      COMMENT: "Provisioning key"
    cmds:
      - mkdir -p .ssh
      - ssh-keygen -t ed25519 -C "${COMMENT}" -f .ssh/{% raw %}{{.SSH_KEY_NAME }}{% endraw %} -N ""
